@startuml

title "Start massive notification job"

actor "IO COM Admin" as admin

box "pushnotif-func"
  participant "StartMassiveJob" as httpfunc
  participant "ProcessMassiveJob" as queuefunc
end box

!pragma teoz true
box "io-p-itn-com-cosno-01 cosmos account" #LightBlue
  box "push-notifications cosmos database"
    database "massive-notification-jobs" as mnj
    database "massive-notification-job-progress" as mnjp
  end box
end box

box "iopitncomst01 Blob Storage account" #LightBlue
  box "Queues"
    database "send-notification" as smq
    database "send-notification-poison" as smpq
    database "check-job-message" as cjmq
  end box
end box

box "Notification Hubs"
  participant "Notification Hub" as nh1
end box

participant "app-insights" as ai

note right of admin
  **Request Params**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B"
  }
end note
admin -> httpfunc : POST /massive-notification-job/:jobId
activate admin
activate httpfunc

httpfunc -> httpfunc : Validate request

alt Invalid request
  httpfunc -[#red]x admin : 400
end

note right of httpfunc
  **Job Document**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
  }
end note
httpfunc -> mnj : Get the job
activate mnj

alt Error from comos
  mnj -[#red]> httpfunc : Transient error
  httpfunc -[#red]x admin : 500
else Job not found
  mnj -[#red]> httpfunc : 404
  httpfunc -[#red]x admin : 404
end


note right of httpfunc
  **Job Document**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "title": "Push notification title",
    "body": "Push notification body",
    "status": "CREATED",
    "executionTimeInHour": 6,
    "startTime": 1771492295
  }
end note
mnj -[#green]> httpfunc : Success
deactivate mnj

httpfunc -> httpfunc : Check if status is valid
alt Status != CREATED
  httpfunc -[#red]x admin : 400
end

httpfunc -> httpfunc : Calculate check's visibilityTimeout as\nstartTime + executionTime - Date.now()
note right of httpfunc
  **CheckNotificationStatusMessage**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "visibilityTimeout": 3600
  }
end note
httpfunc -> cjmq : Push message with visibilityTimeout
alt Transient from the queue
  cjmq -[#red]> httpfunc : Transient
  httpfunc --> ai : Track an event with the message payload.
end

note right of httpfunc
  **Job Document**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "status": "STARTED",
  }
end note
httpfunc -> mnj : Update job status
activate mnj

/'
'  totalTags: Numero totale dei tag. (fisso a livello di function)
'  groupSize: Numero di tag (batch) per ogni invio singolo. (fisso a livello di function)
'  executionTime: Delta tra l'invio della prima e dell'ultima notfica in secondi. (ottenuto dal job)
'
'  delay: Delta tra l'invio di una batch e la successiva.
'
'  delay = executionTime / (totalTags / groupSize)
' '/

alt Error from comos
  mnj -[#red]> httpfunc : Transient error
  httpfunc -[#red]x admin : 500
end

mnj -[#green]> httpfunc : Success
deactivate mnj

note right of httpfunc
  delay = executionTime / (totalTags / groupSize)
end note
httpfunc -> httpfunc : Calculate delay
loop tags / groups of tags
  note right of httpfunc
    scheduledTimestamp = startTime + (delay * iteration)
  end note
  httpfunc -> httpfunc : Calculate schedule timestamp\nbased on iteration and delay
  note right of httpfunc
    **Message**
    {
      "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
      "jobType": "send",
      "scheduledTimestamp": 123456789,
      "tags": ["aaa", "aab", "aac"]
    }
  end note

  httpfunc -> smq : Push message
  activate smq
  alt Transient from the queue
    smq -[#red]> httpfunc : Transient
    note right of httpfunc
      In this case we skip the iteration.
      This failed schedule operation can be retried by hand
      using payload informations in the event.
    end note
    httpfunc --> ai : Track an event with the message payload.
  end

  smq -[#green]> httpfunc : Success
end

note right of admin
  **Response Body**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "status": "STARTED"
  }
end note
httpfunc -[#green]> admin : 200

deactivate httpfunc
deactivate admin

smq -> queuefunc : Dequeue message
activate queuefunc
deactivate smq

queuefunc -> queuefunc : Parse message and validate scheduledTimestamp

alt Invalid message
  note right of queuefunc
    **Message**
    {
      "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
      "scheduledTimestamp": 123456789,
      "tags": ["aaa", "aab", "aac"],
      "error": "Invalid scheduled time"
    }
  end note
  queuefunc --> ai : Track an event
end

queuefunc -> nh1 : Schedule push notification
activate nh1

alt Error from notification hub
  nh1 -[#red]> queuefunc : Transient error
  note right of queuefunc
    **Message**
    {
      "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
      "scheduledTimestamp": 123456789,
      "tags": ["aaa", "aab", "aac"]
    }
  end note

  alt Was last retry
    queuefunc -> smpq : Push to the poison
  
    alt Transient from the queue
      smpq -[#red]> queuefunc : Transient
      queuefunc --> ai : Track an event with the message payload.
    end
  end

  queuefunc -[#red]x queuefunc : Throw an error
end

note right of queuefunc
  **Message**
  {
    "notificationId": "593ca17d-7ccb-43eb-9bdd-e4b0021a24f0"
  }
end note
nh1 -[#green]> queuefunc : 200
deactivate nh1

note right of queuefunc
  **Job Document**
  {
    "notificationId": "593ca17d-7ccb-43eb-9bdd-e4b0021a24f0",
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "scheduledTimestamp": 123456789,
    "completed": false,
    "tags": ["aaa", "aab", "aac"]
  }
end note
queuefunc -> mnjp : Upsert progress
activate mnjp

alt Error from comos
  mnjp -[#red]> queuefunc : Transient error
  note right of queuefunc
    **Message**
    {
      "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
      "jobType": "send",
      "scheduledTimestamp": 123456789,
      "tags": ["aaa", "aab", "aac"],
      "error": "Error from cosmos, notification scheduled correctly as xxx"
    }
  end note
  queuefunc --> ai : Track an event
end

mnjp -[#green]> queuefunc : 201
deactivate mnjp

queuefunc --> ai : Track a success event

deactivate queuefunc

@enduml
