@startuml

title "Check job progress"

queue "check-job-messages" as cjq

queue "check-job-messages-poison" as cjqp

box "pushnotif-func"
  participant "CheckJobProgress" as cjp
end box

!pragma teoz true
box "io-p-itn-com-cosno-01 cosmos account" #LightBlue
  box "push-notifications cosmos database"
    database "massive-jobs" as mj
    database "massive-job-progress" as mjp
  end box
end box

participant "app-insights" as ai

participant "Notification Hub" as nh

note right of cjq
  **CheckNotificationStatusMessage**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B"
  }
end note
cjp -> cjq : Read the check message from the queue
activate cjp

cjp -> cjp : Parse the message

alt Invalid CheckNotificationStatusMessage
  cjp --> ai : Track an event
  note right of cjp
    End the execution.
  end note
end

note right of cjp
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
  }
end note
cjp -> mj : Get the job
activate mj

alt Transient error from cosmos
  mj -[#red]> cjp : Transient error

  alt Was last retry
    cjp -> cjqp : Push to the poison
  end

  cjp -[#red]x cjp : Throw error
else Job not found
  mj -[#red]> cjp : 404
  cjp --> ai : Track an event.
  note right of cjp
    End the execution.
  end note
end

note right of cjp
  **Job Document**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "title": "Push notification title",
    "body": "Push notification body",
    "status": "SCHEDULED",
    "executionTimeInHour": 6,
    "startTime": 1771492295
  }
end note
mj -[#green]> cjp : Success

deactivate mj


cjp -> cjp : Check the status
alt Status != SCHEDULED
  note right of cjp
    In this case the status can be:
    - STOPPED
    - COMPLETED
    - CREATED
    Nothing to do, end the execution.
  end note
end

cjp -> mjp : Get the list of progresses with status `SCHEDULED`
activate mjp
alt Transient error from cosmos
  mjp -[#red]> cjp : Transient error

  alt Was last retry
    cjp -> cjqp : Push to the poison
  end

  cjp -[#red]x cjp : Throw error
else Job not found
  mjp -[#green]> cjp : Empty array response
  note right of cjp
    Everything was updated, we can consider this job COMPLETED.
  end note

  cjp -> mj : Set status to COMPLETED
  activate mj

  alt Transient error from cosmos
    mj -[#red]> cjp : Transient error

    alt Was last retry
      cjp -> cjqp : Push to the poison
    end

    cjp -[#red]x cjp : Throw error
  end

  mj -[#green]> cjp : Success
  note right of cjp
    End the execution.
  end note

  deactivate mj
end

note right of cjp
  [
    {
      "notificationId": "593ca17d-7ccb-43eb-9bdd-e4b0021a24f0",
      "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
      "scheduleTimestamp": 123456789,
      "status": "SCHEDULED",
      "tags": ["aaa", "aab", "aac"]
    },
    ...
  ]

  Note: the jobId is the partition key of the container.
end note
mjp -[#green]> cjp : 200
deactivate mjp

loop For each progress document
  cjp -> nh : Check notification status
  activate nh
  alt Transient error from notfication hub
    nh -[#red]> cjp : Transient

    alt Was last retry
      note left of cjp
        **CheckNotificationStatusMessage**
        {
          "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B"
        }
      end note
      cjp --> cjqp : Push the item to the poison
    end

    cjp -[#red]x cjp : Throw an error

  else Job not found
    cjp --> ai : Track an event
    note right of cjp
      Skip the iteration.
    end note
  end

  nh -[#green]> cjp : Success
  deactivate nh

  alt Status PENDING
      note left of cjp
        **CheckNotificationStatusMessage**
        {
          "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
          "visibilityTimeout": 300
        }

      End the execution.
      end note
    cjp -> cjq : Push the item back in the queue\nto perform the check again in the future.
  end

  note right of cjp
    For other statuses the function just update the document.
  end note

  alt Status ERROR
    cjp --> ai : Track an event.
  end

  cjp -> mjp : Update status

  activate mjp
  alt Transient from cosmos
    mjp -[#red]> cjp : Transient

    alt Was last retry
      cjp -> cjqp : Push to the poison
  end

    cjp -[#red]x cjp : Throw an error
  end
  mjp -[#green]> cjp : Success
  deactivate mjp
end

cjp -> mj : Set the status to COMPLETED
activate mj
alt Transient from cosmos
  mj -[#red]> cjp : Transient

  alt Was last retry
    cjp -> cjqp : Push to the poison
end

  cjp -[#red]x cjp : Throw an error
end
mj -[#green]> cjp : Success
deactivate mj

deactivate cjp

@enduml
