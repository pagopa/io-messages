{
  "name": "io-messages-common-legacy",
  "license": "UNLICENSED",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "exports": {
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "dependencies": {
    "@azure/core-rest-pipeline": "catalog:",
    "@azure/storage-blob": "catalog:",
    "@pagopa/io-functions-commons": "catalog:",
    "@pagopa/ts-commons": "catalog:",
    "io-ts": "catalog:"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsc-alias": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage"
  }
}
