{
  "name": "io-messages-common",
  "license": "UNLICENSED",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "devDependencies": {
    "@azure/functions": "catalog:",
    "@pagopa/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "^3.2.5",
    "tsc-alias": "^1.8.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@azure/functions": "catalog:",
    "pino": "catalog:",
    "ulid": "catalog:",
    "zod": "catalog:"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage"
  }
}
