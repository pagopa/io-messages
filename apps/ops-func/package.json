{
  "name": "ops-func",
  "main": "dist/func.js",
  "version": "1.0.3",
  "type": "module",
  "files": [
    "dist/*",
    "host.json",
    "package.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "esbuild --bundle ./src/func.ts --format=esm --platform=node --target=node22 --outdir=dist --packages=external",
    "build:watch": "pnpm run build --watch",
    "start": "func start",
    "format": "prettier --write .",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@azure/cosmos": "catalog:",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@azure/logger": "catalog:",
    "@azure/storage-blob": "catalog:",
    "io-messages-common": "workspace:^",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
