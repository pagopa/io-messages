@startuml

title InstallationUpdateDispatcher

!pragma teoz true
box "io-p-itn-com-cosno-01 cosmos account" #LightBlue
  box "push-notifications cosmos database"
    database "installation-summaries" as ic
  end box
end box

box "pushnotif-func"
  participant "InstallationUpdateDispatcher" as uai
end box

participant "app-insights" as ai

box "iopitncomst01 storage account"
  queue "update-installations-dispatch" as uiq
end box

uai -> ic : Read document batch\n(change feed trigger)
activate uai

loop for each document
  uai -> uai : Parse document to Installation
  alt Invalid document
    uai --> ai : Track an event
  end
  alt Timestamp passed
    note right of uai
      The function's environment variables include
      a timestamp beyond which updates to installations
      are no longer required.
      Here, we perform a check that prevents pushing to
      the queue if the update is no longer necessary.

      In this case we just end the execution.
    end note
  end

  note right of uai
    **UpdateInstallationMessage**
    {
      "installationId": "ca978112ca1bbdcafac231b39a23dc4da786eff8147c4e72b9807785afee48bb",
      "platform": "FcmV1",
    }
  end note
  uai -> uiq : Push message to the queue
  deactivate uai
end

@enduml
