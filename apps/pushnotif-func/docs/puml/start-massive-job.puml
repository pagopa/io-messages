@startuml

title "Start massive notification job"

actor "IO COM Admin" as admin

box "pushnotif-func"
  participant "StartMassiveJob" as httpfunc
end box

!pragma teoz true
box "io-p-itn-com-cosno-01 cosmos account" #LightBlue
  box "push-notifications cosmos database"
    database "massive-notification-jobs" as mnj
  end box
end box

box "iopitncomst01 Blob Storage account" #LightBlue
  box "Queues"
    queue "process-massive-job" as smq
    queue "check-massive-job" as cjmq
  end box
end box

participant "app-insights" as ai

note right of admin
  **Request Params**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "startTimeTimestamp": 1771492295
  }
end note
admin -> httpfunc : POST /massive-notification-job/:jobId
activate admin
activate httpfunc

httpfunc -> httpfunc : Validate request

alt Invalid request
  httpfunc -[#red]x admin : 400
end

note right of httpfunc
  **Job Document**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
  }
end note
httpfunc -> mnj : Get the job
activate mnj

alt Error from comos
  mnj -[#red]> httpfunc : Transient error
  httpfunc -[#red]x admin : 500
else Job not found
  mnj -[#red]> httpfunc : 404
  httpfunc -[#red]x admin : 404
end


note right of httpfunc
  **Job Document**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "title": "Push notification title",
    "body": "Push notification body",
    "status": "CREATED",
    "executionTimeInHour": 6
  }
end note
mnj -[#green]> httpfunc : Success
deactivate mnj

httpfunc -> httpfunc : Check if status is valid
alt Status != CREATED
  httpfunc -[#red]x admin : 406
end

httpfunc -> httpfunc : Calculate check's visibilityTimeout as\nexecutionTime + 5 minutes of tolerance
note right of httpfunc
  **CheckNotificationStatusMessage**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "visibilityTimeout": 3600
  }
end note
httpfunc -> cjmq : Push message with visibilityTimeout
alt Transient from the queue
  cjmq -[#red]> httpfunc : Transient
  httpfunc -[#red]x admin : 500
end

note right of httpfunc
  **Job Document**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "status": "STARTED",
    "startTimeTimestamp": 1771492295
  }
end note
httpfunc -> mnj : Update job status
activate mnj

/'
'  totalTags: Total number of tags. (fixed at function level)
'  groupSize: Number of tags per batch. (fixed at function level)
'  executionTime: Delta between the first and the last notification sent, in seconds.
'
'  delay: Delta between the first and the last notification sent.
'
'  delay = executionTime / (totalTags / groupSize)
' '/

alt Error from comos
  mnj -[#red]> httpfunc : Transient error
  httpfunc -[#red]x admin : 500
end

mnj -[#green]> httpfunc : Success
deactivate mnj

note right of httpfunc
  delay = executionTime / (totalTags / batchSize)
end note
httpfunc -> httpfunc : Calculate delay
loop tags / batches of tags
  note right of httpfunc
    scheduledTimestamp = startTime + (delay * iteration)
  end note
  httpfunc -> httpfunc : Calculate schedule timestamp\nbased on iteration and delay
  note right of httpfunc
    **ProcessMassiveNotificationMessage**
    {
      "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
      "title": "Push notification title",
      "body": "Push notification body",
      "scheduledTimestamp": 123456789,
      "tags": ["aaa", "aab", "aac"]
    }
  end note

  httpfunc -> smq : Push message
  activate smq
  alt Transient from the queue
    smq -[#red]> httpfunc : Transient
    note right of httpfunc
      In this case we skip the iteration.
      This failed schedule operation can be retried by hand
      using payload informations in the event.
    end note
    httpfunc --> ai : Track event:\n**massiveJob.StartMassiveNotificationJob.scheduleBatch.failed**
  end

  smq -[#green]> httpfunc : Success

  deactivate smq
end

note right of admin
  **Response Body**
  {
    "jobId": "01KHQZBYH4GYY4Z8P5W594JG3B",
    "status": "STARTED"
  }
end note
httpfunc -[#green]> admin : 200

deactivate httpfunc
deactivate admin

@enduml