{
  "name": "pushnotif-func",
  "version": "2.6.0",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/main.js",
  "files": [
    "dist/*",
    "host.json",
    "package.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:generated": "shx rm -rf ./src/generated",
    "build": "tsc",
    "build:watch": "pnpm run build --watch",
    "start": "func start --port 7076",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate": "pnpm generate:backend-notification-hub && pnpm generate:definitions && pnpm generate:session-manager",
    "generate:backend-notification-hub": "shx rm -rf src/generated/notifications && shx mkdir -p src/generated/notifications && gen-api-models --strict 0 --api-spec https://raw.githubusercontent.com/pagopa/io-backend/v19.0.0/notification_queue_messages.yaml --out-dir ./src/generated/notifications",
    "generate:session-manager": "shx rm -rf ./src/generated/session-manager && shx mkdir -p ./src/generated/session-manager && gen-api-models --api-spec https://raw.githubusercontent.com/pagopa/io-auth-n-identity-domain/refs/tags/io-session-manager-internal@0.8.0/apps/io-session-manager-internal/api/internal.yaml --no-strict --out-dir ./src/generated/session-manager --request-types --response-decoders --client",
    "generate:definitions": "shx rm -rf ./src/generated/definitions && shx mkdir -p ./src/generated/definitions && gen-api-models --api-spec ./openapi/index.yaml --no-strict --out-dir ./src/generated/definitions",
    "dist:modules": "modclean -r -n default:safe && pnpm install --production",
    "predeploy": "npm-run-all build dist:*",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/core-rest-pipeline": "^1.23.0",
    "@azure/cosmos": "catalog:",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@azure/notification-hubs": "catalog:",
    "@azure/service-bus": "catalog:",
    "@azure/storage-queue": "catalog:",
    "@pagopa/io-functions-commons": "catalog:",
    "@pagopa/ts-commons": "catalog:",
    "applicationinsights": "catalog:",
    "azure-storage": "catalog:",
    "durable-functions": "catalog:",
    "express": "catalog:",
    "fp-ts": "catalog:",
    "io-ts": "catalog:",
    "node-fetch": "catalog:",
    "ts-pattern": "catalog:",
    "ulid": "catalog:",
    "winston": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@pagopa/openapi-codegen-ts": "catalog:",
    "@types/express-serve-static-core": "catalog:",
    "@types/node": "catalog:",
    "@types/node-fetch": "catalog:",
    "@types/vfile-message": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "modclean": "catalog:",
    "npm-run-all": "catalog:",
    "oval": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
