{
  "name": "etl-func",
  "main": "dist/func.js",
  "type": "module",
  "files": [
    "host.json"
  ],
  "version": "1.0.9",
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "esbuild --bundle ./src/func.ts --format=esm --platform=node --target=node22 --outdir=dist --packages=external",
    "build:watch": "pnpm run build --watch",
    "start": "func start",
    "format": "prettier --write .",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@azure/cosmos": "catalog:",
    "@azure/data-tables": "^13.3.0",
    "@azure/event-hubs": "^5.12.2",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@azure/storage-blob": "^12.26.0",
    "applicationinsights": "catalog:",
    "avsc": "^5.7.7",
    "io-messages-common": "workspace:^",
    "pino": "^9.6.0",
    "redis": "catalog:",
    "ulid": "^3.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "^0.25.2",
    "eslint": "8.57.1",
    "prettier": "3.2.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "license": "UNLICENSED"
}
