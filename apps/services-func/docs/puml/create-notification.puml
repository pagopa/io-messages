@startuml

title Create Notification

queue "message-processed" as inq

box "services-func"
  participant "CreateNotification" as func
end box

!pragma teoz true
box "iopitncomst01 storage account"
  collections "processing-message" as procblob
end box

box "io-p-cosmos-api cosmos account" #LightBlue
  box "db cosmos database"
    database "notifications" as notifdb
  end box
end box

queue "email-notifications" as emailq
queue "webhook-notifications" as webhookq

inq -> func : **ProcessedMessageEvent**\n{blockedInboxOrChannels, messageId, profile}

activate func


func -> func : Parse JSON from queue item

alt Invalid JSON
  func -[#red]x inq : throw Error (retry)
end

func -> func : Decode into **ProcessedMessageEvent**

alt Invalid shape
  func -[#red]x inq : throw Error (retry)
end

func -> procblob : Retrieve **CommonMessageData** blob\nby messageId

activate procblob

alt Error retrieving blob
  procblob -[#red]> func
  func -[#red]x inq : throw Error (retry)
else Blob not found
  procblob -[#red]> func : Empty result
  func -[#red]x inq : throw Error (retry)
end

note right of func
  **CommonMessageData**
  {
    "content": { ... },
    "message": {
      "id": "01KKV476XG8ZY1K4S8RMEFHMQW",
      "fiscalCode": "LVTEST00A00A197X",
      "senderServiceId": "01JR0QRJ8MX1PD06DE6X5FWXS5",
      ...
    },
    "senderMetadata": {
      "serviceName": "...",
      "requireSecureChannels": false,
      "serviceUserEmail": "owner@example.com",
      ...
    }
  }
end note

procblob -[#green]> func : Return CommonMessageData

deactivate procblob

== Email channel decision ==

note right of func
  **blockedInboxOrChannels** is a list of channels
  (EMAIL, WEBHOOK, INBOX) blocked for this sender service.

  **LEGACY mode** is the legacy service block system used for backward compatibility

  Email is considered blocked for this service only when
  the profile is in LEGACY mode AND
  EMAIL appears in the blocked channels list(blockedInboxOrChannels).
end note
func -> func : Check if user blocked EMAIL for this service\n(only relevant in LEGACY preference mode)

note right of func
  **Email address resolution**
  If the fiscalCode in the message matches the test recipient fiscal code, use the service owner email address.
  Otherwise use the email address from the recipient's profile.
end note
func -> func : Resolve candidate email address\n(service owner email for test messages, recipient profile email otherwise)

func -> func : Check sender service allows the email channel\n(not configured as secure-channels-only)

func -> func : Check sender service is not in the email notification blacklist

func -> func : Check recipient has email notifications enabled in profile

func -> func : Check recipient has a validated email address in profile

note right of func
  Email notification is sent only when ALL
  conditions are met:
  - sender service is not in the email blacklist
  - recipient has email notifications enabled in profile
  - recipient has a validated email address in profile
  - recipient has NOT blocked email for this sender service
  - sender service allows the email channel (not secure-channels-only)
  - a candidate email address exists
end note
func -> func : Determine final email address\n(absent if any condition above fails)

== Webhook channel decision ==

func -> func : Check recipient has webhook notifications enabled in profile

func -> func : Check recipient has NOT blocked webhook notifications for this sender service

note right of func
  Webhook notification is sent only when:
  - recipient has webhook notifications enabled in profile
  - recipient has NOT blocked webhook notifications for this sender service
end note
func -> func : Determine final webhook URL\n(absent if any condition above fails)

== No channels guard ==

alt no email address AND no webhook URL resolved
  note right of func
    No channels are configured for this
    recipient. Nothing to do.
  end note
  func -> func : End execution\n(RESULT=NO_CHANNELS_ENABLED)
end

== Save Notification to CosmosDB ==

note right of func
  **NewNotification**
  {
    "id": "<ulid>",
    "fiscalCode": "LVTEST00A00A197X",
    "messageId": "01KKV476XG8ZY1K4S8RMEFHMQW",
    "channels": {
      "EMAIL": { "toAddress": "...", "addressSource": "..." },
      "WEBHOOK": { "url": "https://..." }
    }
  }
end note
func -> func : Build NewNotification\n(createNewNotification + channels)

func -> notifdb : Create notification document

activate notifdb

alt Error from Cosmos
  notifdb -[#red]> func
  func -[#red]x inq : throw Error\n(Cannot save notification to database)
end

notifdb -[#green]> func : Return saved Notification\n(with generated id)

deactivate notifdb

== Enqueue output events ==

opt email address was resolved

  note right of func
    **NotificationCreatedEvent**
    { messageId, notificationId }
  end note
  func -> emailq : Enqueue **NotificationCreatedEvent**

end

opt webhook URL was resolved

  func -> webhookq : Enqueue **NotificationCreatedEvent**

end

deactivate func

@enduml
