{
  "bindings": [
    {
      "queueName": "%NOTIFICATION_CREATED_WEBHOOK_QUEUE_NAME%",
      "connection": "IO_COM_STORAGE_CONNECTION_STRING",
      "name": "norificationCreatedWebhook",
      "type": "queueTrigger",
      "direction": "in"
    }
  ],
  "retry": {
    "strategy": "exponentialBackoff",
    "maxRetryCount": 5,
    "minimumInterval": "00:00:30",
