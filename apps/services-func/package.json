{
  "name": "services-func",
  "version": "2.0.5",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/main.js",
  "files": [
    "dist/*",
    "host.json",
    "package.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:generated": "shx rm -rf ./src/generated",
    "build": "tsc",
    "watch": "tsc --w",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "start": "func start --port 7073",
    "version": "pnpm bump:openapi",
    "bump:openapi": "pnpm node copy-commons-definitions.js && bundle-api-spec -i openapi/index.yaml -o openapi/index.yaml -V $npm_package_version && git add openapi/index.yaml",
    "generate": "pnpm bump:openapi && pnpm generate:definitions && pnpm generate:pagopa-ecommerce && pnpm generate:notify && pnpm generate:remote-content",
    "generate:definitions": "shx rm -rf ./src/generated/definitions && shx rm -rf mkdir -p ./src/generated/definitions && gen-api-models --api-spec ./openapi/index.yaml --no-strict --out-dir ./src/generated/definitions",
    "generate:remote-content": "shx rm -rf src/generated/remote-content && gen-api-models --api-spec https://raw.githubusercontent.com/pagopa/io-functions-services-messages/master/openapi/index_external.yaml --no-strict --out-dir src/generated/remote-content --request-types --response-decoders --client",
    "generate:pagopa-ecommerce": "shx rm -rf src/generated/pagopa-ecommerce && shx rm -rf mkdir -p src/generated/pagopa-ecommerce && gen-api-models --api-spec ./openapi/pagopa-ecommerce.yaml --no-strict --out-dir ./src/generated/pagopa-ecommerce --request-types --response-decoders --client",
    "generate:notify": "shx rm -rf src/generated/notify && shx rm -rf mkdir -p src/generated/notify && gen-api-models --api-spec ./openapi/notify.yaml --no-strict --out-dir ./src/generated/notify --request-types --response-decoders --client",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@pagopa/openapi-codegen-ts": "catalog:",
    "@types/documentdb": "catalog:",
    "@types/express-serve-static-core": "catalog:",
    "@types/html-to-text": "catalog:",
    "@types/lolex": "catalog:",
    "@types/node": "catalog:",
    "@types/node-fetch": "catalog:",
    "@types/nodemailer": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@azure/cosmos": "catalog:",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@azure/storage-queue": "catalog:",
    "@pagopa/io-app-email-templates": "catalog:",
    "@pagopa/io-backend-notifications-sdk": "catalog:",
    "@pagopa/io-functions-admin-sdk": "catalog:",
    "@pagopa/io-functions-commons": "catalog:",
    "@pagopa/ts-commons": "catalog:",
    "abort-controller": "catalog:",
    "applicationinsights": "catalog:",
    "azure-storage": "catalog:",
    "date-fns": "catalog:",
    "documentdb": "catalog:",
    "express": "catalog:",
    "fast-check": "catalog:",
    "fp-ts": "catalog:",
    "html-to-text": "catalog:",
    "io-ts": "catalog:",
    "io-ts-types": "catalog:",
    "lolex": "catalog:",
    "monocle-ts": "catalog:",
    "newtype-ts": "catalog:",
    "node-fetch": "catalog:",
    "nodemailer": "catalog:",
    "redis": "catalog:",
    "remove-markdown": "catalog:",
    "semver": "catalog:",
    "ts-pattern": "catalog:",
    "winston": "catalog:"
  }
}
