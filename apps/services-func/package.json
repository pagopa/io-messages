{
  "name": "services-func",
  "version": "2.0.3",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:generated": "shx rm -rf ./src/generated",
    "build": "tsc",
    "watch": "tsc --w",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "start": "func start --port 7073",
    "version": "pnpm bump:openapi",
    "bump:openapi": "pnpm node copy-commons-definitions.js && bundle-api-spec -i openapi/index.yaml -o openapi/index.yaml -V $npm_package_version && git add openapi/index.yaml",
    "generate": "pnpm bump:openapi && pnpm generate:definitions && pnpm generate:pagopa-ecommerce && pnpm generate:notify && pnpm generate:remote-content",
    "generate:definitions": "rimraf ./src/generated/definitions && shx mkdir -p ./src/generated/definitions && gen-api-models --api-spec ./openapi/index.yaml --no-strict --out-dir ./src/generated/definitions",
    "generate:remote-content": "rimraf src/generated/remote-content && gen-api-models --api-spec https://raw.githubusercontent.com/pagopa/io-functions-services-messages/master/openapi/index_external.yaml --no-strict --out-dir src/generated/remote-content --request-types --response-decoders --client",
    "generate:pagopa-ecommerce": "rimraf src/generated/pagopa-ecommerce && shx mkdir -p src/generated/pagopa-ecommerce && gen-api-models --api-spec ./openapi/pagopa-ecommerce.yaml --no-strict --out-dir ./src/generated/pagopa-ecommerce --request-types --response-decoders --client",
    "generate:notify": "rimraf src/generated/notify && shx mkdir -p src/generated/notify && gen-api-models --api-spec ./openapi/notify.yaml --no-strict --out-dir ./src/generated/notify --request-types --response-decoders --client",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@pagopa/openapi-codegen-ts": "catalog:",
    "@types/documentdb": "^1.10.13",
    "@types/express-serve-static-core": "^4.17.33",
    "@types/html-to-text": "catalog:",
    "@types/lolex": "^5.1.6",
    "@types/node": "catalog:",
    "@types/node-fetch": "^2.5.7",
    "@types/nodemailer": "^4.6.2",
    "@types/semver": "^7",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "8.57.1",
    "prettier": "3.2.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@azure/cosmos": "catalog:",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@azure/storage-queue": "^12.4.0",
    "@pagopa/io-app-email-templates": "^0.7.3",
    "@pagopa/io-backend-notifications-sdk": "^9.7.0",
    "@pagopa/io-functions-admin-sdk": "^1.10.1",
    "@pagopa/io-functions-commons": "catalog:",
    "@pagopa/ts-commons": "catalog:",
    "abort-controller": "catalog:",
    "applicationinsights": "catalog:",
    "azure-storage": "catalog:",
    "date-fns": "^4.1.0",
    "documentdb": "^1.15.3",
    "express": "catalog:",
    "fast-check": "^1.16.0",
    "fp-ts": "catalog:",
    "html-to-text": "^4.0.0",
    "io-ts": "catalog:",
    "io-ts-types": "^0.5.19",
    "lolex": "^6.0.0",
    "monocle-ts": "^2.3.13",
    "newtype-ts": "^0.3.5",
    "node-fetch": "^2.6.7",
    "nodemailer": "^6.4.16",
    "redis": "catalog:",
    "remove-markdown": "^0.5.0",
    "semver": "^7.7.2",
    "ts-pattern": "^4.0.5",
    "winston": "^3.2.1"
  }
}
