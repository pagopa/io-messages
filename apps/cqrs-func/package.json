{
  "name": "cqrs-func",
  "author": "IO team",
  "version": "2.0.4",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/main.js",
  "files": [
    "dist/*",
    "host.json",
    "package.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:generated": "shx rm -rf ./src/generated",
    "build": "tsc",
    "build:watch": "pnpm run build --watch",
    "start": "func start --port 7075",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "dist:modules": "modclean -r -n default:safe && pnpm install --production",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@pagopa/openapi-codegen-ts": "^11.1.0",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/node-fetch": "catalog:",
    "@types/vfile-message": "catalog:",
    "dotenv-cli": "^3.1.0",
    "eslint": "catalog:",
    "modclean": "catalog:",
    "npm-run-all": "catalog:",
    "oval": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@azure/cosmos": "catalog:",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@azure/storage-queue": "catalog:",
    "@pagopa/fp-ts-kafkajs": "catalog:",
    "@pagopa/io-functions-commons": "catalog:",
    "io-messages-common-legacy": "workspace:*",
    "@pagopa/ts-commons": "catalog:",
    "applicationinsights": "catalog:",
    "avsc": "catalog:",
    "@azure/storage-blob": "catalog:",
    "express": "catalog:",
    "fp-ts": "catalog:",
    "io-ts": "catalog:",
    "kafkajs": "catalog:",
    "node-fetch": "catalog:",
    "winston": "catalog:"
  }
}
