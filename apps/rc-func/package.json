{
  "name": "rc-func",
  "main": "dist/main.js",
  "version": "2.0.8",
  "license": "UNLICENSED",
  "type": "commonjs",
  "files": [
    "dist/*",
    "host.json",
    "package.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:generated": "shx rm -rf ./src/generated",
    "build": "tsc",
    "build:watch": "pnpm run build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "start": "func start",
    "generate": "pnpm generate:definitions && pnpm generate:backend-notification-hub && pnpm generate:session-manager",
    "generate:definitions": "shx rm -rf ./src/generated/definitions && shx mkdir -p ./src/generated/definitions && gen-api-models --api-spec ./openapi/index.yaml --no-strict --out-dir ./src/generated/definitions",
    "generate:backend-notification-hub": "shx rm -rf ./src/generated/notifications && shx mkdir -p ./src/generated/notifications && gen-api-models --strict 0 --api-spec https://raw.githubusercontent.com/pagopa/io-backend/v8.10.1/notification_queue_messages.yaml --out-dir ./src/generated/notifications",
    "generate:session-manager": "shx rm -rf ./src/generated/session-manager && shx mkdir -p ./src/generated/session-manager && gen-api-models --api-spec https://raw.githubusercontent.com/pagopa/io-auth-n-identity-domain/refs/tags/io-session-manager-internal@0.8.0/apps/io-session-manager-internal/api/internal.yaml --no-strict --out-dir ./src/generated/session-manager --request-types --response-decoders --client",
    "version": "pnpm bump:openapi:internal && pnpm bump:openapi:external",
    "bump:openapi:internal": "bundle-api-spec -i openapi/index.yaml -o openapi/index.yaml -V $npm_package_version && git add openapi/index.yaml",
    "bump:openapi:external": "bundle-api-spec -i openapi/index_external.yaml -o openapi/index_external.yaml -V $npm_package_version && git add openapi/index_external.yaml",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@pagopa/openapi-codegen-ts": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/node-fetch": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@azure/cosmos": "catalog:",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@pagopa/io-functions-commons": "catalog:",
    "@pagopa/ts-commons": "catalog:",
    "abort-controller": "catalog:",
    "applicationinsights": "catalog:",
    "express": "catalog:",
    "fp-ts": "catalog:",
    "io-ts": "catalog:",
    "node-fetch": "catalog:",
    "redis": "catalog:",
    "ts-pattern": "catalog:",
    "winston": "catalog:"
  }
}
