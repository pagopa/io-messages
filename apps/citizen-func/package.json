{
  "name": "citizen-func",
  "version": "6.0.2",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/main.js",
  "files": [
    "dist/*",
    "host.json",
    "package.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:generated": "shx rm -rf ./src/generated",
    "build": "tsc",
    "build:watch": "pnpm run build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "openapi:bundle": "pnpm bundle-api-spec -i openapi/index.yaml -o openapi/index.yaml -V $npm_package_version",
    "dist:modules": "modclean -r -n default:safe && pnpm install --production",
    "version": "pnpm openapi:bundle",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "generate": "pnpm openapi:bundle && pnpm generate:definitions",
    "generate:definitions": "shx rm -rf src/generated/definitions && shx mkdir -p src/generated/definitions && gen-api-models --api-spec ./openapi/index.yaml --no-strict --out-dir ./src/generated/definitions",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "start": "func start --port 7072"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "catalog:",
    "@pagopa/openapi-codegen-ts": "catalog:",
    "@types/express": "catalog:",
    "@types/html-to-text": "catalog:",
    "@types/node": "catalog:",
    "@types/redis": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "modclean": "catalog:",
    "prettier": "catalog:",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@azure/cosmos": "catalog:",
    "@azure/functions": "catalog:",
    "@azure/identity": "catalog:",
    "@pagopa/io-functions-commons": "catalog:",
    "@pagopa/ts-commons": "catalog:",
    "applicationinsights": "catalog:",
    "azure-storage": "catalog:",
    "express": "catalog:",
    "fp-ts": "catalog:",
    "io-ts": "catalog:",
    "redis": "catalog:"
  }
}
