{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^generate", "generate", "^build"],
      "inputs": ["src/**/*.ts", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"],
      "outputLogs": "errors-only"
    },
    "lint": {
      "inputs": ["src/**/*.ts"],
      "outputLogs": "errors-only"
    },
    "lint:check": {
      "inputs": ["src/**/*.ts"],
      "outputLogs": "errors-only"
    },
    "test": {
      "dependsOn": ["generate", "^build"],
      "inputs": ["src/**/*.ts"],
      "outputLogs": "full"
    },
    "format": {
      "outputLogs": "errors-only"
    },
    "format:check": {
      "outputLogs": "errors-only"
    },
    "typecheck": {
      "dependsOn": ["generate", "^build"],
      "inputs": ["src/**/*.ts", "package.json", "tsconfig.json"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "generate": {
      "inputs": [
        "avro/**/*.json",
        "openapi/**/*.yaml",
        "openapi/**/*.yaml.template"
      ],
      "outputs": ["src/generated/**/*.ts"],
      "outputLogs": "errors-only"
    },
    "test:coverage": {
      "dependsOn": ["generate", "^build"],
      "inputs": ["src/**/*.ts"],
      "outputs": ["coverage/**"],
      "outputLogs": "errors-only"
    },
    "version": {},
    "clean": {
      "cache": false
    }
  }
}
